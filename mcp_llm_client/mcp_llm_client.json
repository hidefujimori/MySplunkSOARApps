{
    "appid": "4b7776cf-253e-43ec-bd94-f929e8fcebb6",
    "name": "MCP LLM Client",
    "package_name": "phantom_mcp_llm_client",
    "description": "MCP (Model Context Protocol) Client that connects to MCP servers (e.g. Splunk MCP Server) and routes prompts to configurable LLM providers (Anthropic Claude, OpenAI, Google Gemini, Azure OpenAI).",
    "publisher": "PoC",
    "type": "information service",
    "main_module": "mcp_llm_client_connector.py",
    "app_version": "1.0.0",
    "product_vendor": "Generic",
    "product_name": "MCP LLM Client",
    "product_version_regex": ".*",
    "min_phantom_version": "6.0.0",
    "python_version": "3",
    "logo": "mcp_llm_client.svg",
    "logo_dark": "mcp_llm_client_dark.svg",
    "license": "Copyright (c) 2024 PoC",
    "configuration": {
        "mcp_server_url": {
            "description": "MCP Server URL (e.g. https://your-splunk-mcp-server:8000)",
            "data_type": "string",
            "required": true,
            "order": 0
        },
        "mcp_server_token": {
            "description": "Bearer token for MCP Server authentication (if required)",
            "data_type": "password",
            "required": false,
            "order": 1
        },
        "llm_provider": {
            "description": "LLM Provider to use for processing prompts",
            "data_type": "string",
            "required": true,
            "value_list": [
                "anthropic",
                "openai",
                "gemini",
                "azure_openai"
            ],
            "default": "anthropic",
            "order": 2
        },
        "llm_api_key": {
            "description": "API Key for the selected LLM provider",
            "data_type": "password",
            "required": true,
            "order": 3
        },
        "llm_model": {
            "description": "Model name to use (e.g. claude-sonnet-4-20250514, gpt-4o, gemini-1.5-pro)",
            "data_type": "string",
            "required": true,
            "order": 4
        },
        "llm_api_base_url": {
            "description": "Custom API Base URL (required for Azure OpenAI)",
            "data_type": "string",
            "required": false,
            "order": 5
        },
        "max_tokens": {
            "description": "Maximum number of tokens in LLM response",
            "data_type": "numeric",
            "default": 1024,
            "required": false,
            "order": 6
        },
        "request_timeout": {
            "description": "HTTP request timeout in seconds",
            "data_type": "numeric",
            "default": 60,
            "required": false,
            "order": 7
        },
        "verify_ssl_mcp": {
            "description": "Verify SSL certificate for MCP Server (disable for self-signed certs in PoC environments)",
            "data_type": "boolean",
            "default": true,
            "required": false,
            "order": 8
        },
        "verify_ssl_llm": {
            "description": "Verify SSL certificate for LLM API (disable for self-signed certs in PoC environments)",
            "data_type": "boolean",
            "default": true,
            "required": false,
            "order": 9
        }
    },
    "actions": [
        {
            "action": "test connectivity",
            "description": "Validate the asset configuration for connectivity to MCP Server and LLM provider",
            "verbose": "Connects to the configured MCP Server using JSON-RPC 2.0 initialize handshake and retrieves the list of available tools.",
            "type": "test",
            "identifier": "test_asset_connectivity",
            "read_only": true,
            "parameters": {},
            "output": [],
            "versions": "EQ(*)"
        },
        {
            "action": "send prompt",
            "description": "Send a prompt to the LLM via MCP Server and return the response",
            "verbose": "Retrieves available tools from the MCP Server, then sends the prompt along with tool context to the configured LLM provider.",
            "type": "investigate",
            "identifier": "send_prompt",
            "read_only": true,
            "parameters": {
                "prompt": {
                    "description": "User prompt to send to the LLM",
                    "data_type": "string",
                    "required": true,
                    "primary": true,
                    "order": 0
                },
                "system_prompt": {
                    "description": "System prompt to guide LLM behavior (optional)",
                    "data_type": "string",
                    "required": false,
                    "order": 1
                },
                "use_mcp_tools": {
                    "description": "Include available MCP tools context in the prompt",
                    "data_type": "boolean",
                    "default": true,
                    "required": false,
                    "order": 2
                }
            },
            "output": [
                {
                    "data_path": "action_result.data.*.llm_response",
                    "data_type": "string",
                    "column_name": "LLM Response",
                    "column_order": 0
                },
                {
                    "data_path": "action_result.data.*.finish_reason",
                    "data_type": "string",
                    "column_name": "Finish Reason",
                    "column_order": 1
                },
                {
                    "data_path": "action_result.data.*.provider",
                    "data_type": "string",
                    "column_name": "Provider",
                    "column_order": 2
                },
                {
                    "data_path": "action_result.data.*.model",
                    "data_type": "string",
                    "column_name": "Model",
                    "column_order": 3
                },
                {
                    "data_path": "action_result.data.*.mcp_tools_available",
                    "data_type": "string",
                    "column_name": "MCP Tools",
                    "column_order": 4
                },
                {
                    "data_path": "action_result.status",
                    "data_type": "string",
                    "column_name": "Status",
                    "column_order": 5
                },
                {
                    "data_path": "action_result.message",
                    "data_type": "string"
                },
                {
                    "data_path": "action_result.summary.llm_provider",
                    "data_type": "string"
                },
                {
                    "data_path": "action_result.summary.mcp_tools_count",
                    "data_type": "numeric"
                },
                {
                    "data_path": "action_result.summary.finish_reason",
                    "data_type": "string"
                }
            ],
            "render": {
                "type": "table"
            },
            "versions": "EQ(*)"
        },
        {
            "action": "list mcp tools",
            "description": "Retrieve the list of available tools from the MCP Server",
            "verbose": "Connects to the MCP Server and returns all available tools with their descriptions and input schemas.",
            "type": "investigate",
            "identifier": "list_mcp_tools",
            "read_only": true,
            "parameters": {},
            "output": [
                {
                    "data_path": "action_result.data.*.name",
                    "data_type": "string",
                    "column_name": "Tool Name",
                    "column_order": 0
                },
                {
                    "data_path": "action_result.data.*.description",
                    "data_type": "string",
                    "column_name": "Description",
                    "column_order": 1
                },
                {
                    "data_path": "action_result.status",
                    "data_type": "string",
                    "column_name": "Status",
                    "column_order": 2
                },
                {
                    "data_path": "action_result.summary.tool_count",
                    "data_type": "numeric"
                }
            ],
            "render": {
                "type": "table"
            },
            "versions": "EQ(*)"
        }
    ]
}